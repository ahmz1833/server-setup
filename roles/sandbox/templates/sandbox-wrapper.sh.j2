#!/bin/bash
# Managed by Ansible

# Prevent execution without virtual user mapping
if [ -z "$1" ]; then
    echo "Access Denied: Virtual identity not provided."
    exit 1
fi

VIRTUAL_USER="$1"
CONTAINER="sandbox-$VIRTUAL_USER"

# Check if the mapped container is running
if ! /usr/bin/docker ps -q -f name=^/${CONTAINER}$ >/dev/null; then
    echo "Access Denied: Sandbox environment '${VIRTUAL_USER}' is offline or does not exist."
    exit 1
fi

# Execute the requested command or provide an interactive shell
if [ -n "$SSH_ORIGINAL_COMMAND" ]; then
    exec /usr/bin/docker exec -i "$CONTAINER" /bin/bash -c "$SSH_ORIGINAL_COMMAND"
else
    exec /usr/bin/docker exec -it "$CONTAINER" /bin/bash
fi
